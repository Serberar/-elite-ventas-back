# ==========================================
# CRM ELITE BACKEND
# ==========================================

# =====================
# FRONTEND
# =====================
# URL del frontend para redirects y cookies
FRONTEND_URL=http://elitedeventas.duckdns.org

# =====================
# BASE DE DATOS
# =====================
#DESARROLLO
DATABASE_URL="postgresql://postgres:1234@localhost:5432/crm?schema=public&connection_limit=10"
#PRODUCTION
#DATABASE_URL="postgresql://elite:EliteVentas2025*@192.168.1.47:5432/buscador?schema=public&connection_limit=10"

# =====================
# PUERTO
# =====================
PORT=3001

# =====================
# CORS (OPCIONAL)
# =====================
# true = cualquier IP puede acceder
# false = solo IPs permitidas pueden acceder
ALLOW_ALL_CORS=true
# IPs permitidas (solo se usan si ALLOW_ALL_CORS=false)
CORS1=http://192.168.1.47:5173
CORS2=http://elitedeventas.duckdns.org
CORS3=http://192.168.1.50:5173

# =====================
# JWT - AUTENTICACIÓN
# =====================
JWT_SECRET=fsG4jX9mR1vQ8zK2pW0dN7bT3qL5uC6yE8aS0fH2gV9rD3xM1nP4cJ7tZ5vR8yQ0
JWT_EXPIRES_IN=8h

JWT_REFRESH_SECRET=Y3h8pD5sV9uR1fT4bG7jN2mK6zL0wC8eQ5xH9vS3aP1tB4nR2yF0gM7dJ8lW6uZ9
JWT_REFRESH_EXPIRES_IN=7d

# =====================
# ENTORNO
# =====================
NODE_ENV=production

# =====================
# RATE LIMIT
# =====================
# true = deshabilita el rate limit de login
# false o no definido = rate limit activo
DISABLE_AUTH_RATE_LIMIT=true

# =====================
# MÉTRICAS Y MONITOREO
# =====================
ENABLE_METRICS=true
# Puerto para métricas (opcional, usa PORT por defecto)
PROMETHEUS_PORT=9090
# =====================
# LLEIDA.NET - FIRMA ELECTRÓNICA (Click & Sign)
# =====================
# API Key de autenticación (cabecera Authorization: x-api-key)
LLEIDA_API_KEY=your_api_key_here
# Usuario de Lleida.net
LLEIDA_USER=your_username_here
# Forzar mock de firma (true = no llama a Lleida, ideal para demo/testing)
LLEIDA_USE_MOCK=false
# ID de la configuración de correo en Lleida.net
LLEIDA_CONFIG_ID_CORREO=12345
# ID de la configuración SMS de Lleida.net
LLEIDA_CONFIG_ID_SMS=
