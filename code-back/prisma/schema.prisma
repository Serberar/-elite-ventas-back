generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum Role {
  administrador @map("administrador")
  verificador   @map("verificador")
  coordinador   @map("coordinador")
  comercial     @map("comercial")
}

model Empresa {
  id                 String   @id @default(uuid())
  nombre             String
  slug               String   @unique
  activa             Boolean  @default(true)

  // Personalización visual
  logo               String?  // URL
  colorPrimario      String?  // hex
  colorSecundario    String?  // hex
  colorNombreEmpresa String?  // hex — color del nombre en la barra de navegación (defecto blanco)

  // Páginas visibles (claves: "buscador", "aplicaciones", "ventas"…)
  paginasHabilitadas String[]
  paginaInicio        String?  // clave de la página de inicio (ej: "buscador", "ventas"…)

  createdAt          DateTime @default(now())

  // Relaciones
  users         User[]
  clients       Client[]
  products      Product[]
  sales         Sale[]
  saleStatuses  SaleStatus[]
  allowedIps    AllowedIp[]
  settings      SystemSetting[]
}

model User {
  id                    String    @id @default(uuid())
  firstName             String
  lastName              String
  username              String    @unique
  password              String
  role                  Role      @default(administrador)
  active                Boolean   @default(true)
  failedLoginAttempts   Int       @default(0)
  createdAt             DateTime  @default(now())
  lastLoginAt           DateTime?
  refreshToken          String?
  refreshTokenExpiresAt DateTime?

  empresaId             String
  empresa               Empresa   @relation(fields: [empresaId], references: [id])

  // relaciones inversas
  assignments        SaleAssignment[]
  saleHistories      SaleHistory[]
  uploadedRecordings SaleRecording[]

  @@index([empresaId])
}

model Client {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  dni          String
  email        String
  birthday     String
  phones       String[]
  addresses    Json
  bankAccounts String[]
  authorized   String?
  businessName String?
  comments     String[]
  createdAt    DateTime @default(now())
  lastModified DateTime @updatedAt

  empresaId    String
  empresa      Empresa  @relation(fields: [empresaId], references: [id])

  sales Sale[]

  @@index([dni])
  @@index([phones(ops: ArrayOps)], type: Gin)
  @@index([createdAt])
  @@index([empresaId])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  sku         String?
  price       Decimal
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Tipo de pago
  tipo          String   @default("unico")   // 'unico' | 'periodico' | 'consumo'
  periodo       String?                       // 'semanal'|'mensual'|'trimestral'|'semestral'|'anual'
  precioBase    Decimal?                      // consumo: cuota fija base
  precioConsumo Decimal?                      // consumo: precio por unidad (kWh, m³…)
  unidadConsumo String?                       // consumo: etiqueta de unidad ('kWh', 'm³', 'hora'…)

  empresaId     String
  empresa       Empresa  @relation(fields: [empresaId], references: [id])

  saleItems SaleItem[]

  @@unique([sku, empresaId])  // SKU único por empresa (no global)
  @@index([empresaId])
}

model Sale {
  id       String @id @default(uuid())
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  statusId String
  status   SaleStatus @relation(fields: [statusId], references: [id])

  totalAmount     Decimal @default(0)
  notes           Json?   // [{message, userId, role, createdAt}]
  metadata        Json?

  clientSnapshot  Json?   // snapshot del cliente editado en el front
  addressSnapshot Json?   // snapshot de la dirección seleccionada
  comercial       String? // nombre del comercial que hace la venta

  empresaId       String
  empresa         Empresa @relation(fields: [empresaId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?

  items             SaleItem[]
  assignments       SaleAssignment[]
  histories         SaleHistory[]
  recordings        SaleRecording[]
  signatureRequests SignatureRequest[]

  @@index([clientId])
  @@index([statusId])
  @@index([comercial])
  @@index([createdAt])
  @@index([createdAt, statusId])
  @@index([empresaId])
}

model SignatureRequest {
  id                 String    @id @default(uuid())
  saleId             String
  documentType       String    @default("contract") // "contract" | "consent"
  sale               Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)

  status             String    // "pending" | "signed" | "rejected"
  signerEmail        String
  providerDocumentId String?
  signedDocumentUrl  String?
  rejectionReason    String?

  sentAt             DateTime?
  signedAt           DateTime?
  rejectedAt         DateTime?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([saleId, documentType])
  @@index([saleId])
  @@index([status])
  @@index([providerDocumentId])
}

model SaleItem {
  id     String @id @default(uuid())
  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  nameSnapshot String
  skuSnapshot  String?
  unitPrice    Decimal
  quantity     Int
  finalPrice   Decimal

  // Snapshots del tipo de producto al momento de la venta
  tipoSnapshot          String?
  periodoSnapshot       String?
  precioBaseSnapshot    Decimal?
  precioConsumoSnapshot Decimal?
  unidadConsumoSnapshot String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([saleId])
  @@index([productId])
}

model SaleStatus {
  id          String  @id @default(uuid())
  name        String
  order       Int
  color       String?
  isFinal     Boolean @default(false)
  isCancelled Boolean @default(false)
  isSystem    Boolean @default(false)

  empresaId   String
  empresa     Empresa @relation(fields: [empresaId], references: [id])

  sales Sale[]

  @@index([empresaId])
}

model SaleHistory {
  id     String @id @default(uuid())
  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action    String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([saleId])
}

model SaleAssignment {
  id       String @id @default(uuid())
  saleId   String
  sale     Sale   @relation(fields: [saleId], references: [id])

  userId   String
  user     User   @relation(fields: [userId], references: [id])

  role      String
  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([userId])
}

model SaleRecording {
  id           String   @id @default(uuid())
  saleId       String
  sale         Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  filename     String   // nombre original del archivo
  storagePath  String   // ruta relativa: records/{saleId}/{uuid}.ext
  mimeType     String   // audio/mpeg, audio/wav, video/mp4, etc.
  size         Int      // tamaño en bytes

  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])

  createdAt    DateTime @default(now())

  @@index([saleId])
}

model AllowedIp {
  id          String   @id @default(uuid())
  ip          String
  description String?
  createdAt   DateTime @default(now())

  empresaId   String
  empresa     Empresa  @relation(fields: [empresaId], references: [id])

  @@unique([ip, empresaId])  // IP única por empresa (no global)
  @@index([empresaId])
}

model SystemSetting {
  key       String
  value     String

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id])

  @@id([key, empresaId])  // Clave primaria compuesta
  @@index([empresaId])
}
